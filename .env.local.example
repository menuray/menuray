# ============================================================
#  MenuRay — Local environment template
# ============================================================
#
#  Copy this file to `.env.local` and fill in the values from
#  your own Supabase project (Settings → API / Database).
#
#  `.env.local` is gitignored — never commit real values.
# ============================================================

# --- Supabase project -------------------------------------------------
# Project URL, e.g. https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Project ref — the subdomain portion of SUPABASE_URL
# e.g. if SUPABASE_URL=https://abc123xyz.supabase.co
# then SUPABASE_PROJECT_REF=abc123xyz
SUPABASE_PROJECT_REF=

# Publishable / anon key — safe to expose to client code.
# Find at: Supabase → Settings → API → Project API keys
SUPABASE_ANON_KEY=

# ⚠ Service role (secret) key — full DB access, bypasses RLS.
# Server-side / Edge Functions only. NEVER bundle in client builds.
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres direct connection --------------------------------------
# Only needed for direct psql / schema migrations outside Supabase CLI.
# Most CLI commands authenticate via `supabase login` and don't need these.
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=
